# ----------------------------------------------------------
# METHOD 1: GENERATE POWER SET USING BITMASKS (Two Loops)
# ----------------------------------------------------------
"""
[METHOD 1: PSEUDOCODE]
START
    INPUT main_set (list)
    SET set_size = length of main_set
    SET total_subsets = 2 SHIFT LEFT set_size
    SET power_set = empty list
    
    FOR i from 0 to total_subsets - 1:
        SET current_subset = empty list
        FOR j from 0 to set_size - 1:
            # Check if the j-th bit of integer 'i' is set
            IF (i AND (1 SHIFT LEFT j)) NOT EQUAL 0 THEN
                APPEND main_set[j] to current_subset
            END IF
        END FOR
        APPEND current_subset to power_set
    END FOR
    OUTPUT power_set
END
"""

def generate_power_set(main_set):
    # Time Complexity: O(n * 2^n) - Where n is the number of elements
    # Space Complexity: O(n * 2^n) - To hold all generated subsets
    n = len(main_set)
    total_subsets = 1 << n  # Equivalent to 2^n combinations
    power_set = []
    
    # Outer loop runs from binary 000... to 111...
    for i in range(total_subsets):
        current_subset = []
        # Inner loop acts as a bit probe checking each index
        for j in range(n):
            if (i & (1 << j)) != 0:
                current_subset.append(main_set[j])
        power_set.append(current_subset)
        
    return power_set


# ----------------------------------------------------------
# METHOD 2: BIT PROBE & BIT DIFFERENCE (Hamming Distance)
# ----------------------------------------------------------
"""
[METHOD 2: PSEUDOCODE]
START
    INPUT num1, num2
    SET xor_result = num1 XOR num2
    SET count = 0
    WHILE xor_result > 0:
        IF (xor_result AND 1) EQUALS 1 THEN
            count = count + 1
        END IF
        xor_result = xor_result RIGHT SHIFT 1
    END WHILE
    OUTPUT count
END
"""

def check_bit_probe(number, position):
    """Probes a single bit position to see if it is active (1) or inactive (0)"""
    mask = 1 << position
    return (number & mask) != 0


def count_bit_difference(num1, num2):
    # Time Complexity: O(Number of bits)
    # Space Complexity: O(1)
    # XOR highlights different bits as '1's
    xor_result = num1 ^ num2
    difference_count = 0
    
    while xor_result > 0:
        difference_count += xor_result & 1
        xor_result >>= 1  # Shift right to inspect next bit position
        
    return difference_count


