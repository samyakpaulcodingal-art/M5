# ----------------------------------------------------------
# METHOD 1: FIND ONE ODD OCCURRING NUMBER (XOR Cancellation)
# ----------------------------------------------------------
"""
[METHOD 1: PSEUDOCODE]
START
    INPUT numbers_list
    SET unique_clue = 0
    FOR each num in numbers_list:
        SET unique_clue = unique_clue XOR num
    END FOR
    OUTPUT unique_clue
END
"""

def find_single_clue(numbers_list):
    # Time Complexity: O(n) - Single pass through the array
    # Space Complexity: O(1) - Constant auxiliary space
    unique_clue = 0
    
    for num in numbers_list:
        unique_clue ^= num  # XOR operation
        
    return unique_clue


# ----------------------------------------------------------
# METHOD 2: FIND TWO ODD OCCURRING NUMBERS (Rightmost Set Bit)
# ----------------------------------------------------------
"""
[METHOD 2: PSEUDOCODE]
START
    INPUT numbers_list
    SET xor_sum = 0
    FOR each num in numbers_list:
        xor_sum = xor_sum XOR num
    END FOR
    
    # Isolate the rightmost set bit
    SET rightmost_set_bit = xor_sum AND (NOT (xor_sum - 1))
    
    SET clue1 = 0
    SET clue2 = 0
    
    # Divide elements into two buckets based on the set bit
    FOR each num in numbers_list:
        IF (num AND rightmost_set_bit) NOT EQUAL 0 THEN
            clue1 = clue1 XOR num
        ELSE
            clue2 = clue2 XOR num
        END IF
    END FOR
    
    OUTPUT clue1, clue2
END
"""

def find_two_clues(numbers_list):
    # Time Complexity: O(n) - Two independent single passes
    # Space Complexity: O(1)
    
    # Step 1: XOR all elements to get XOR sum of the two unique numbers
    xor_sum = 0
    for num in numbers_list:
        xor_sum ^= num
        
    # Step 2: Extract the rightmost set bit (first bit where they differ)
    rightmost_set_bit = xor_sum & ~(xor_sum - 1)
    
    clue1 = 0
    clue2 = 0
    
    # Step 3: Divide numbers into two groups and XOR separately
    for num in numbers_list:
        if num & rightmost_set_bit:
            clue1 ^= num  # Group with the bit set
        else:
            clue2 ^= num  # Group with the bit not set
            
    return sorted([clue1, clue2])


