    print(f"Case A List (One Odd Number)  : {case_a_list}")
    print(f"Investigated Single Clue      : {find_single_clue(case_a_list)}\n")
    print("-" * 60)
    
    # Scenario B: Two numbers appear an odd number of times (all others appear twice)
    case_b_list = [2, 3, 7, 9, 11, 2, 3, 11]
    # Explanation: 2, 3, 11 cancel out. 7 and 9 are the two clues.
    print(f"Case B List (Two Odd Numbers) : {case_b_list}")
    print(f"Investigated Two Clues        : {find_two_clues(case_b_list)}")
    print("-" * 60)


