    # 2. Testing Left Shift Doubling
    value = 23
    print("[Bitwise Multiplication]")
    print(f"  Original Value     : {value}")
    print(f"  Doubled (value << 1): {double_number(value)}\n")
    print("-" * 50)
    
    # 3. Testing Sign Detection via XOR
    val1, val2 = 10, -20
    val3, val4 = -5, -15
    print("[Sign Detection Challenge]")
    print(f"  Do {val1} and {val2} have different signs? {detect_different_signs(val1, val2)}")
    print(f"  Do {val3} and {val4} have different signs? {detect_different_signs(val3, val4)}\n")
    print("-" * 50)
    
    # 4. Testing Right Shift Division
    target = 100
    print("[Bitwise Division]")
    print(f"  Original Value      : {target}")
    print(f"  Divided by 2 (n >> 1): {divide_by_two(target)}")
    print("-" * 50)


