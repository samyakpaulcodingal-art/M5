# ----------------------------------------------------------
# BITWISE CHALLENGE FUNCTIONS
# ----------------------------------------------------------
"""
[PSEUDOCODE: XOR SWAP]
START
    INPUT a, b
    SET a = a XOR b
    SET b = a XOR b
    SET a = a XOR b
    OUTPUT a, b
END
"""

def xor_swap(a, b):
    # Time Complexity: O(1)
    # Space Complexity: O(1) - Swaps completely in-place without a third variable
    a = a ^ b
    b = a ^ b
    a = a ^ b
    return a, b


def double_number(n):
    # Time Complexity: O(1)
    # Shifting bits left by 1 position effectively multiplies the number by 2
    return n << 1


def detect_different_signs(x, y):
    # Time Complexity: O(1)
    # If signs are different, the sign bit (most significant bit) of their XOR will be 1
    # resulting in a negative number (< 0)
    return (x ^ y) < 0


def divide_by_two(n):
    # Time Complexity: O(1)
    # Shifting bits right by 1 position divides the integer by 2 (floor division)
    return n >> 1


