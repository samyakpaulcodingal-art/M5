# EXECUTION / TESTING THE CODE
# ==========================================================
if __name__ == "__main__":
    print("--- Power of Two Scanner Active ---\n")
    
    # 1. Test Power Scanner Operations
    test_numbers = [8, 16, 64, 40]
    for num in test_numbers:
        print(f"Scanning Number: {num}")
        print(f"  > Is Power of 2? {is_power_of_two(num)}")
        print(f"  > Is Power of 4? {is_power_of_four(num)}")
        print(f"  > Is Power of 8? {is_power_of_eight(num)}")
        print(f"  > Clearing rightmost bit leaves: {remove_rightmost_set_bit(num)}\n")
    
    print("-" * 60)
    
    # 2. Test Binary Exponentiation
    b, e = 3, 10
    print(f"Calculating {b}^{e} using Fast Binary Exponentiation...")
    print(f"Result: {power_fast(b, e)}")
    print("-" * 60)


